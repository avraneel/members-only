<main class="messages">
    <% for (let i = messages.length - 1; i >= 0; i--) { %>
        <article class="message">
            <%= messages[i].text %>
            <% if(currentUser) { %>
                <p>- <%= messages[i].first_name %> <%= messages[i].last_name %>, <%= messages[i].timestamp %></p>
            <% } %>
        </article>
    <% }; %>
</main>