<nav class="navbar">
  <% if (currentUser) { %>
    <div class="greeting">
      <h1>Welcome back, <%= currentUser.first_name %></h1>
    </div>
  <% } %>
  <ul>
    <li><a href="/">Home</a></li>
    <% if (!currentUser) { %>
      <li><a href="/login">Login</a></li>
      <li><a href="/signup">Signup</a></li>
    <% } else { %>
      <li><a href="/member">Join Us!</a></li>
      <li><a href="/logout">Logout</a></li>
    <% } %>
  </ul>
</nav>
