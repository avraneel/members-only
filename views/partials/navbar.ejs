<nav class="block navbar">
  <% if (currentUser) { %>
    <div class="greeting navitem">
      <h3>Welcome back, <%= currentUser.first_name %></h1>
    </div>
    <p class="status navitem">Status: <%= currentUser.status %></p>
  <% } else { %>
    <h3>Members Only</h3>
  <% } %>
  <ul class="menu navitem">
    <li><a href="/">Home</a></li>
    <% if (!currentUser) { %>
      <li><a href="/login">Login</a></li>
      <li><a href="/signup">Signup</a></li>
    <% } else { %>
      <li><a href="/member">Join Us!</a></li>
      <li><a href="/logout">Logout</a></li>
    <% } %>
  </ul>
</nav>
